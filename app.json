{
  "expo": {
    "name": "GREEN THUMB FINAL PROJECT",
    "slug": "GREEN-THUMB-FINAL-PROJECT",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./LOGO1.png",
    "scheme": "green",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.paul.greenthumb",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Green Thumb uses your location to show local weather for plant care.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Green Thumb uses your location to show local weather for plant care."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E9E9E9",
        "foregroundImage": "./LOGO1.png",
        "monochromeImage": "./LOGO1.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.luap_omsim.GREEN"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./LOGO1.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./LOGO1.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2243eb3c-e704-4965-9d52-bb0fc6611a1b"
      }
    }
  }
}
